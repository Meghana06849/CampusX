{
  "installCommand": "npm --prefix tpo-tracker-backend install && npm --prefix tpo-tracker-frontend install",
  "buildCommand": "npm --prefix tpo-tracker-frontend run build",
  "outputDirectory": "tpo-tracker-frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
