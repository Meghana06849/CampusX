{
  "installCommand": "cd tpo-tracker-backend && npm install && cd .. && cd tpo-tracker-frontend && npm install",
  "buildCommand": "cd tpo-tracker-frontend && npm run build",
  "outputDirectory": "tpo-tracker-frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
